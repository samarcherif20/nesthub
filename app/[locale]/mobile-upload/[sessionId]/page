// ============================================================
// STEP CARD COMPONENT
// ============================================================

interface StepCardProps {
  type: DocumentType;
  document: DocumentState;
  onCapture: (e: React.ChangeEvent<HTMLInputElement>) => void;
  onRemove: () => void;
  fileInputRef: React.RefObject<HTMLInputElement | null>;
}

function StepCard({ type, document: doc, onCapture, onRemove, fileInputRef }: StepCardProps) {
  const config = DOC_CONFIGS[type];
  const isUploaded = doc.status === "uploaded";
  const isUploading = doc.status === "uploading";
  const isCaptured = doc.status === "captured";
  const isError = doc.status === "error";
  const isSelfie = type === "selfie";

  return (
    <div
      className={`
        relative rounded-2xl overflow-hidden transition-all duration-500
        ${isUploaded
          ? "bg-white dark:bg-slate-900 border-2 border-emerald-500/50"
          : isError
          ? "bg-white dark:bg-slate-900 border-2 border-rose-500/50"
          : "bg-white/90 dark:bg-slate-900/80 border border-slate-200 dark:border-slate-800"
        }
        backdrop-blur-sm
      `}
    >
      {isUploading && <Loader message={`Envoi ${config.title}…`} />}

      {/* Top accent bar - Dégradé NestHub */}
      <div
        className="h-1 w-full"
        style={{
          background: isUploaded
            ? "linear-gradient(90deg, #10b981, #34d399)"
            : isError
            ? "linear-gradient(90deg, #f43f5e, #fb7185)"
            : "linear-gradient(90deg, #005cab, #712ae2)",
        }}
      />

      <div className="p-5">
        {/* Header */}
        <div className="flex items-center justify-between mb-4">
          <div className="flex items-center gap-3">
            <div
              className={`w-10 h-10 rounded-xl flex items-center justify-center transition-all duration-300 ${
                isUploaded
                  ? "bg-emerald-50 dark:bg-emerald-950/50 text-emerald-600 dark:text-emerald-400"
                  : isError
                  ? "bg-rose-50 dark:bg-rose-950/50 text-rose-600 dark:text-rose-400"
                  : `${config.bgClass} ${config.colorClass}`
              }`}
            >
              {isUploaded ? <IconCheckCircle className="w-5 h-5" /> : config.icon}
            </div>

            <div>
              <h3 className="font-bold text-slate-900 dark:text-white text-base">{config.title}</h3>
              <p className="text-slate-500 dark:text-slate-400 text-xs mt-0.5">
                {isUploaded
                  ? "Document validé"
                  : isError
                  ? doc.errorMessage
                  : isCaptured
                  ? "Photo prise"
                  : config.subtitle}
              </p>
            </div>
          </div>

          {isUploaded && (
            <span className="bg-emerald-50 dark:bg-emerald-950/50 text-emerald-700 dark:text-emerald-300 text-[10px] font-bold px-3 py-1 rounded-full">
              ✓ Validé
            </span>
          )}
          {isCaptured && !isUploaded && (
            <span className="bg-blue-50 dark:bg-blue-950/50 text-blue-700 dark:text-blue-300 text-[10px] font-bold px-3 py-1 rounded-full">
              Prêt
            </span>
          )}
        </div>

        {/* Photo area */}
        {doc.preview ? (
          <div className="space-y-3">
            <div
              className={`relative w-full overflow-hidden rounded-xl border-2 border-dashed ${
                isUploaded
                  ? "border-emerald-500/50"
                  : "border-[#005cab]/30 dark:border-[#712ae2]/30"
              } ${isSelfie ? "max-w-[200px] mx-auto aspect-[3/4]" : config.aspectClass}`}
            >
              <img src={doc.preview} alt={config.title} className="w-full h-full object-cover" />
              {isUploaded && (
                <div className="absolute bottom-2 right-2 w-8 h-8 bg-emerald-500 rounded-full flex items-center justify-center shadow-lg">
                  <IconCheckCircle className="w-5 h-5 text-white" />
                </div>
              )}
            </div>

            {(isCaptured || isError) && (
              <div className="flex gap-2">
                <button
                  onClick={() => fileInputRef.current?.click()}
                  className="flex-1 py-2.5 rounded-xl bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-200 font-medium text-sm flex items-center justify-center gap-2 active:scale-95 transition-transform"
                >
                  <IconRetake className="w-4 h-4" />
                  Reprendre
                </button>
                <button
                  onClick={onRemove}
                  className="py-2.5 px-4 rounded-xl bg-rose-50 dark:bg-rose-950/30 text-rose-600 dark:text-rose-400 font-medium text-sm flex items-center justify-center gap-1.5 active:scale-95 transition-transform"
                >
                  <IconDelete className="w-4 h-4" />
                  Supprimer
                </button>
              </div>
            )}
          </div>
        ) : (
          <div
            onClick={() => fileInputRef.current?.click()}
            className={`relative w-full overflow-hidden cursor-pointer active:scale-[0.98] transition-transform group
              ${isSelfie ? "max-w-[200px] mx-auto aspect-[3/4]" : config.aspectClass}
              rounded-xl border-2 border-dashed border-slate-300 dark:border-slate-600
              bg-slate-50 dark:bg-slate-800/30
              flex flex-col items-center justify-center gap-2
              hover:border-[#005cab] dark:hover:border-[#712ae2] transition-colors
