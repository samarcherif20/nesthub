          >
            <div className={`w-12 h-12 rounded-xl flex items-center justify-center ${config.bgClass}`}>
              <IconAddPhoto className={`w-6 h-6 ${config.colorClass}`} />
            </div>
            <div className="text-center">
              <p className="text-slate-600 dark:text-slate-400 text-xs font-medium">Appuyez pour capturer</p>
              <p className="text-slate-400 dark:text-slate-500 text-[10px] mt-0.5">
                {isSelfie ? "Caméra frontale" : "Caméra arrière"}
              </p>
            </div>
          </div>
        )}
      </div>

      <input
        ref={fileInputRef}
        type="file"
        accept="image/*"
        capture={config.capture}
        className="hidden"
        onChange={onCapture}
      />
    </div>
  );
}

