    colorClass: "text-[#005cab] dark:text-blue-400",
    bgClass: "bg-[#005cab]/10 dark:bg-[#005cab]/20",
    capture: "environment",
    aspectClass: "aspect-[1.586/1]",
    stepNumber: 1,
  },
  verso: {
    title: "CIN Verso",
    subtitle: "Face arrière de votre carte",
    helper: "Retournez votre carte et capturez le verso avec tous les détails visibles",
    icon: <IconBadge className="w-6 h-6" />,
    colorClass: "text-[#712ae2] dark:text-purple-400",
    bgClass: "bg-[#712ae2]/10 dark:bg-[#712ae2]/20",
    capture: "environment",
    aspectClass: "aspect-[1.586/1]",
    stepNumber: 2,
  },
  selfie: {
    title: "Selfie Live",
    subtitle: "Photo de votre visage",
    helper: "Placez votre visage bien centré dans le cadre, dans un endroit lumineux",
    icon: <IconFace className="w-6 h-6" />,
    colorClass: "text-[#4b41e1] dark:text-indigo-400",
    bgClass: "bg-[#4b41e1]/10 dark:bg-[#4b41e1]/20",
    capture: "user",
    aspectClass: "aspect-[3/4] max-w-[220px] mx-auto",
    stepNumber: 3,
