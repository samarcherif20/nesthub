// MAIN PAGE
// ============================================================

export default function MobileUploadPage() {
  const params = useParams();
  const router = useRouter();
  const sessionId = params.sessionId as string;
  const { resolvedTheme, setTheme } = useTheme();
  const [mounted, setMounted] = useState(false);

  const [pageLoading, setPageLoading] = useState(true);
  const [uploading, setUploading] = useState(false);
  const [uploadProgress, setUploadProgress] = useState(0);
  const [allUploaded, setAllUploaded] = useState(false);

  const [currentStepIndex, setCurrentStepIndex] = useState(0);
  const [animState, setAnimState] = useState<"idle" | "exit" | "enter">("idle");
  const [animDirection, setAnimDirection] = useState<"forward" | "backward">("forward");
  const [pendingStepIndex, setPendingStepIndex] = useState<number | null>(null);

  const [documents, setDocuments] = useState<Record<DocumentType, DocumentState>>({
    recto: { file: null, preview: null, status: "idle" },
    verso: { file: null, preview: null, status: "idle" },
    selfie: { file: null, preview: null, status: "idle" },
  });

  const fileInputRefs = {
    recto: useRef<HTMLInputElement>(null),
    verso: useRef<HTMLInputElement>(null),
    selfie: useRef<HTMLInputElement>(null),
  };

  const currentType = STEP_ORDER[currentStepIndex];
  const currentConfig = DOC_CONFIGS[currentType];
  const currentDocument = documents[currentType];

  useEffect(() => {
    setMounted(true);
    const timer = setTimeout(() => setPageLoading(false), 500);
    return () => clearTimeout(timer);
  }, []);

  const isDark = mounted && resolvedTheme === "dark";

  const goToStep = useCallback(
    (nextIndex: number) => {
      if (nextIndex < 0 || nextIndex > 2 || nextIndex === currentStepIndex || animState !== "idle") return;
      const dir = nextIndex > currentStepIndex ? "forward" : "backward";
      setAnimDirection(dir);
      setPendingStepIndex(nextIndex);
      setAnimState("exit");
      setTimeout(() => {
        setCurrentStepIndex(nextIndex);
        setAnimState("enter");
        setTimeout(() => {
          setAnimState("idle");
          setPendingStepIndex(null);
        }, 350);
      }, 280);
    },
    [currentStepIndex, animState]
  );

  const goNext = useCallback(() => {
    if (currentStepIndex < 2 && animState === "idle") goToStep(currentStepIndex + 1);
  }, [currentStepIndex, goToStep, animState]);

  const goPrev = useCallback(() => {
    if (currentStepIndex > 0 && animState === "idle") goToStep(currentStepIndex - 1);
  }, [currentStepIndex, goToStep, animState]);

  const handleCapture = useCallback(
    (type: DocumentType) => (e: React.ChangeEvent<HTMLInputElement>) => {
      const file = e.target.files?.[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = () => {
        setDocuments((prev) => ({
          ...prev,
          [type]: { file, preview: reader.result as string, status: "captured" },
        }));
        const stepIndex = STEP_ORDER.indexOf(type);
        if (stepIndex < STEP_ORDER.length - 1) {
          setTimeout(() => goToStep(stepIndex + 1), 600);
        }
      };
      reader.readAsDataURL(file);
      if (fileInputRefs[type].current) fileInputRefs[type].current!.value = "";
    },
    [goToStep]
  );

  const handleRemove = useCallback((type: DocumentType) => {
    setDocuments((prev) => ({
      ...prev,
      [type]: { file: null, preview: null, status: "idle" },
    }));
  }, []);

  const handleDiscardAll = useCallback(() => {
    setDocuments({
      recto: { file: null, preview: null, status: "idle" },
      verso: { file: null, preview: null, status: "idle" },
      selfie: { file: null, preview: null, status: "idle" },
    });
    setAllUploaded(false);
    setUploadProgress(0);
    if (currentStepIndex !== 0 && animState === "idle") goToStep(0);
  }, [currentStepIndex, goToStep, animState]);

  const handleUploadAll = useCallback(async () => {
    const toUpload = Object.entries(documents).filter(
      ([, doc]) => doc.status === "captured" && doc.file
    ) as [DocumentType, DocumentState][];
    if (toUpload.length === 0) return;

    setUploading(true);
    setUploadProgress(5);

    setDocuments((prev) => {
      const next = { ...prev };
      toUpload.forEach(([type]) => {
        next[type] = { ...next[type], status: "uploading" };
      });
      return next;
    });

    let successfullyUploaded = Object.values(documents).filter((d) => d.status === "uploaded").length;

    for (let i = 0; i < toUpload.length; i++) {
      const [type, doc] = toUpload[i];
      const formData = new FormData();
      formData.append("sessionId", sessionId);
      formData.append("type", type);
      formData.append("file", doc.file!);

      try {
        const res = await fetch("/api/mobile-upload/upload", { method: "POST", body: formData });
        if (res.ok) {
          successfullyUploaded += 1;
          setDocuments((prev) => ({
            ...prev,
            [type]: { ...prev[type], status: "uploaded" },
          }));
        } else {
          throw new Error();
        }
      } catch {
        setDocuments((prev) => ({
          ...prev,
          [type]: { ...prev[type], status: "error", errorMessage: "Erreur lors de l'envoi" },
        }));
      }
      setUploadProgress(Math.round(((i + 1) / toUpload.length) * 100));
    }

    setUploading(false);
    if (successfullyUploaded === 3) setAllUploaded(true);
  }, [documents, sessionId]);

  const uploadedCount = Object.values(documents).filter((d) => d.status === "uploaded").length;
  const hasAnyContent = Object.values(documents).some((d) => d.status !== "idle");
  const allStepsReady = STEP_ORDER.every((type) => {
    const s = documents[type].status;
    return s === "captured" || s === "uploaded";
  });

  const barPct = allUploaded ? 100 : ((currentStepIndex + (currentDocument.status !== "idle" ? 0.5 : 0)) / 3) * 100;

  if (pageLoading) return <LoadingSpinner />;

  return (
    <div
      className={`min-h-screen transition-colors duration-700 ${
        isDark
          ? "bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900"
          : "bg-gradient-to-br from-slate-50 via-white to-slate-100"
      }`}
    >
      <style jsx global>{`
        @keyframes exitLeft {
          from { transform: translateX(0) scale(1); opacity: 1; }
          to { transform: translateX(-40px) scale(0.96); opacity: 0; }
        }
        @keyframes exitRight {
          from { transform: translateX(0) scale(1); opacity: 1; }
          to { transform: translateX(40px) scale(0.96); opacity: 0; }
        }
        @keyframes enterFromRight {
          from { transform: translateX(40px) scale(0.96); opacity: 0; }
          to { transform: translateX(0) scale(1); opacity: 1; }
        }
        @keyframes enterFromLeft {
          from { transform: translateX(-40px) scale(0.96); opacity: 0; }
          to { transform: translateX(0) scale(1); opacity: 1; }
        }
        .card-exit-left { animation: exitLeft 280ms ease-in-out forwards; }
        .card-exit-right { animation: exitRight 280ms ease-in-out forwards; }
        .card-enter-right { animation: enterFromRight 350ms ease-out forwards; }
        .card-enter-left { animation: enterFromLeft 350ms ease-out forwards; }
      `}</style>

      {/* Header */}
      <header className="sticky top-0 w-full z-50 bg-white/80 dark:bg-slate-900/80 backdrop-blur-xl border-b border-slate-200 dark:border-slate-800">
        <div className="flex justify-between items-center px-4 py-3 max-w-lg mx-auto">
          <button
            onClick={() => {
              if (currentStepIndex > 0 && animState === "idle") goPrev();
              else router.back();
            }}
            className="w-9 h-9 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center active:scale-95 transition-transform"
          >
            <IconArrowBack className="w-4 h-4 text-slate-600 dark:text-slate-300" />
          </button>

          <div className="flex items-center gap-2">
            <div className="relative w-8 h-8">
              <Image src="/logo/logo.png" alt="NestHub" fill className="object-contain" />
            </div>
            <span className="text-lg font-bold bg-gradient-to-r from-blue-600 to-purple-600 bg-clip-text text-transparent">
              NESTHUB
            </span>
          </div>

          <button
            onClick={() => setTheme(isDark ? "light" : "dark")}
            className="w-9 h-9 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center active:scale-95 transition-transform"
          >
            {isDark ? "☀️" : "🌙"}
          </button>
        </div>

        {/* Progress bar - Dégradé NestHub */}
        <div className="h-[2px] bg-slate-100 dark:bg-slate-800">
          <div
            className="h-full transition-all duration-500"
            style={{
              width: `${barPct}%`,
              background: allUploaded ? "#10b981" : "linear-gradient(90deg, #005cab, #712ae2)",
            }}
          />
        </div>
      </header>

      {/* Main */}
      <main className="px-4 pt-6 pb-48 max-w-lg mx-auto w-full">
        {/* Title */}
        <div className="text-center mb-6">
          <h1 className="text-2xl font-bold text-slate-800 dark:text-white">{currentConfig.title}</h1>
          <p className="text-sm text-slate-500 dark:text-slate-400 mt-1">
            Étape {currentStepIndex + 1} sur 3 · {currentConfig.subtitle}
          </p>
        </div>

        {/* Step indicators */}
        <div className="flex justify-center gap-2 mb-6">
          {STEP_ORDER.map((type, idx) => {
            const doc = documents[type];
            const isComplete = doc.status === "captured" || doc.status === "uploaded";
            return (
              <div
                key={type}
                onClick={() => animState === "idle" && goToStep(idx)}
                className={`h-1.5 w-12 rounded-full cursor-pointer transition-all duration-300 ${
                  idx === currentStepIndex
                    ? "bg-gradient-to-r from-blue-600 to-purple-600 w-16"
                    : isComplete
                    ? "bg-emerald-500"
                    : "bg-slate-300 dark:bg-slate-700"
                }`}
              />
            );
          })}
        </div>

        {/* Animated Card */}
        <div className="relative" style={{ minHeight: 400 }}>
          <div className={animState === "exit" ? (animDirection === "forward" ? "card-exit-left" : "card-exit-right") : animState === "enter" ? (animDirection === "forward" ? "card-enter-right" : "card-enter-left") : ""}>
            <StepCard
              type={currentType}
              document={currentDocument}
              onCapture={handleCapture(currentType)}
              onRemove={() => handleRemove(currentType)}
              fileInputRef={fileInputRefs[currentType]}
            />
          </div>
        </div>

        {/* Security note */}
        <div className="mt-6 p-3 rounded-xl bg-slate-50 dark:bg-slate-800/30 border border-slate-200 dark:border-slate-800 flex items-start gap-2">
          <IconShield className="w-4 h-4 text-emerald-500 mt-0.5" />
          <p className="text-slate-500 dark:text-slate-400 text-[11px] leading-relaxed">
            Vos données sont chiffrées de bout en bout et traitées uniquement pour la vérification d'identité.
          </p>
        </div>
      </main>

      {/* Footer */}
      <footer className="fixed bottom-0 left-0 w-full z-40 bg-gradient-to-t from-white dark:from-slate-900 via-white/95 dark:via-slate-900/95 to-transparent pt-6 pb-6 px-4">
        <div className="max-w-lg mx-auto space-y-3">
          {/* Continue button - Dégradé NestHub */}
          {!uploading && !allUploaded && currentStepIndex < 2 && currentDocument.status === "captured" && animState === "idle" && (
            <button
              onClick={goNext}
              className="w-full py-3.5 rounded-xl bg-gradient-to-r from-blue-600 to-purple-600 text-white font-bold text-sm active:scale-95 transition-transform flex items-center justify-center gap-2"
            >
              Continuer
              <IconArrowForward className="w-4 h-4" />
            </button>
          )}

          {/* Upload button - Dégradé NestHub */}
          {!uploading && !allUploaded && currentStepIndex === 2 && allStepsReady && animState === "idle" && (
            <button
              onClick={handleUploadAll}
              className="w-full py-3.5 rounded-xl bg-gradient-to-r from-blue-600 to-purple-600 text-white font-bold text-sm active:scale-95 transition-transform flex items-center justify-center gap-2"
            >
              <IconUpload className="w-4 h-4" />
              Envoyer tous les documents
            </button>
          )}

          {/* Upload progress */}
          {uploading && (
            <div className="w-full py-3 rounded-xl bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 flex flex-col gap-2 px-4">
              <div className="flex items-center gap-3">
                <div className="relative w-5 h-5">
                  <div className="absolute inset-0 border-2 border-slate-200 rounded-full" />
                  <div className="absolute inset-0 border-2 border-transparent border-t-blue-600 rounded-full animate-spin" />
                </div>
                <div className="flex-1 h-1.5 bg-slate-100 dark:bg-slate-800 rounded-full overflow-hidden">
                  <div className="h-full bg-gradient-to-r from-blue-600 to-purple-600 rounded-full transition-all duration-300" style={{ width: `${uploadProgress}%` }} />
                </div>
                <span className="text-xs font-bold text-slate-600 dark:text-slate-400">{uploadProgress}%</span>
              </div>
              <p className="text-slate-500 dark:text-slate-400 text-[10px] text-center">Envoi des documents...</p>
            </div>
          )}

          {/* Success */}
          {allUploaded && !uploading && (
            <div className="w-full py-3.5 rounded-xl bg-emerald-500 text-white font-bold text-sm flex items-center justify-center gap-2">
              <IconCheckCircle className="w-4 h-4" />
              Tous les documents envoyés !
            </div>
          )}

          {/* Discard */}
          {hasAnyContent && !uploading && !allUploaded && animState === "idle" && (
            <button
              onClick={handleDiscardAll}
              className="w-full py-3 rounded-xl border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-400 font-medium text-sm active:scale-95 transition-transform flex items-center justify-center gap-2"
            >
              <IconDiscard className="w-4 h-4" />
              Tout effacer
            </button>
          )}
        </div>
      </footer>
    </div>
  );
}



