generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  PROPERTY_OWNER
  TENANT
  BOTH
  CO_HOST // ✅ AJOUTER CETTE LIGNE
}

enum AccountStatus {
  ACTIVE
  TEMPORARILY_SUSPENDED
  PERMANENTLY_BANNED
  PENDING_VALIDATION
  SECURITY_LOCKED
  INACTIVE
  REJECTED
  ANUALLY_BLOCKED
  MANUALLY_BLOCKED
}

enum VerificationStatus {
  PENDING
  VALIDATED
  REJECTED
  REAPPLIED
}

model User {
  id                     String        @id @default(uuid())
  clerkId                String        @unique
  email                  String        @unique
  username               String?       @unique
  firstName              String?
  lastName               String?
  dateOfBirth            DateTime?
  governorate            String?
  delegation             String?
  gender                 String?
  phoneNumber            String?       @unique
  phoneVerifiedAt        DateTime?
  profilePictureUrl      String?
  bio                    String?
  spokenLanguages        String[]      @default([])
  preferredLocale        String        @default("fr")
  role                   UserRole      @default(TENANT)
  profession             String?
  availability           Json?
  howFound               String? // google, social, friend, ads, other
  rib                    String?
  bankName               String?
  accountHolder          String?
  status                 AccountStatus @default(PENDING_VALIDATION)
  isEmailVerified        Boolean       @default(false)
  isPhoneVerified        Boolean       @default(false)
  isIdentityVerified     Boolean       @default(false)
  cinNumber              String?       @unique
  cinData                Json?
  verifiedAt             DateTime?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  lastLogin              DateTime?
  deletedAt              DateTime?
  suspendedUntil         DateTime?
  failedLoginAttempts    Int           @default(0)
  escalationLevel        Int?
  escalationReason       String?
  escalatedAt            DateTime?
  vacationMode           Boolean       @default(false)
  vacationMessage        String?
  vacationStartDate      DateTime?
  vacationEndDate        DateTime?
  twoFactorEnabled       Boolean       @default(false)
  twoFactorRecoveryCodes String?
  stripeCustomerId       String?       @unique
  stripeAccountId        String?       @unique // Pour Stripe Connect (versements propriétaires)
  // Relations Admin
  riskScore              Int?          @default(50) // ← AJOUTÉ
  acceptsForeigners      Boolean?

  writtenNotes            AdminNote[]           @relation("AuthorUser")
  adminNotes              AdminNote[]           @relation("TargetUser")
  auditLogs               AuditLog[]
  emailLogs               EmailLog[]
  staticPageVersions      StaticPageVersion[]   @relation("UserStaticPageVersions")
  actionsPerformed        UserAction[]          @relation("AdminUser")
  userActions             UserAction[]
  loginHistory            UserLoginHistory[]
  reportsReceived         UserReport[]          @relation("ReportedUser")
  reportsMade             UserReport[]          @relation("Reporter")
  stats                   UserStats?
  verificationRequests    VerificationRequest[] @relation("UserVerificationRequests")
  verifiedRequests        VerificationRequest[] @relation("AdminReviewedVerifications")
  verificationActions     VerificationAction[]  @relation("AdminVerificationActions")
  otpCodes                OtpCode[]
  identityVerification    IdentityVerification?
  notificationPreferences Json? // Stocke les préférences de l'utilisateur

  // ============================================
  // RELATIONS SPRINT 2
  // ============================================

  // Annonces (Listing)
  listings Listing[] @relation("UserListings")

  // Réservations
  tenantBookings Booking[] @relation("TenantBookings")
  ownerBookings  Booking[] @relation("OwnerBookings")

  // Co-locataires
  tenantCoTenants CoTenant[] @relation("TenantCoTenants")
  coTenantInvites CoTenant[] @relation("CoTenantUsers")

  // Messages pour les réservations (BookingMessage)
  sentBookingMessages     BookingMessage[] @relation("SentMessages")
  receivedBookingMessages BookingMessage[] @relation("ReceivedMessages")

  // Messages pour le chat (Message)
  sentChatMessages     Message[] @relation("SentMessages")
  receivedChatMessages Message[] @relation("ReceivedMessages")

  // Favoris
  favorites     Favorite[]
  favoriteLists FavoriteList[]

  // Alertes
  searchAlerts SearchAlert[]

  // Notifications
  notifications Notification[]

  // Avis
  reviewsWritten  Review[] @relation("ReviewsWritten")
  reviewsReceived Review[] @relation("ReviewsReceived")

  // Signalements
  listingReports ListingReport[] @relation("ListingReports")

  // Litiges
  openedDisputes   Dispute[] @relation("OpenedDisputes")
  assignedDisputes Dispute[] @relation("AssignedDisputes")

  // Messages litiges
  disputeMessages DisputeMessage[] @relation("DisputeMessages")

  // Historique
  searchHistory      SearchHistory[]
  mapViews           MapView[]
  listingComparisons ListingComparison[]
  listingHistories   ListingHistory[]
  sentInvitations    CoOwnerInvitation[] @relation("CoOwnerInvitationsSent")
  teamMemberships    TeamMember[]
  contactMessages ContactMessage[]

  // Conversations (chat)
  conversationsAsOwner  Conversation[] @relation("OwnerConversations")
  conversationsAsTenant Conversation[] @relation("TenantConversations")

  // SPRINT 3 - NOUVELLES RELATIONS
  infoRequestsAsTenant InfoRequest[] @relation("InfoRequestTenant")
  infoRequestsAsOwner  InfoRequest[] @relation("InfoRequestOwner")
  offersAsTenant       Offer[]       @relation("OfferTenant")
  offersAsOwner        Offer[]       @relation("OfferOwner")

  // Pour les blocages (Block)
  blocksCreated  Block[] @relation("blocks")
  blocksReceived Block[] @relation("blockedBy")

  // Pour les signalements (Report)
  reportsCreated      Report[]             @relation("reports")
  reportReceived      Report[]             @relation("reported")
  paymentTransactions PaymentTransaction[] // 👈 Relation inverse pour PaymentTransaction

  @@index([email])
  @@index([status])
  @@index([role])
  @@index([createdAt])
  @@index([cinNumber])
  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  usedAt    DateTime?

  @@index([email])
  @@index([token])
}

model OtpCode {
  id          String   @id @default(uuid())
  userId      String
  phoneNumber String
  code        String
  expiresAt   DateTime
  used        Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([phoneNumber])
  @@index([expiresAt])
  @@map("otp_codes")
}

model IdentityVerification {
  id               String             @id @default(uuid())
  userId           String             @unique
  documentFrontUrl String?
  documentBackUrl  String?
  submissionDate   DateTime?
  processedDate    DateTime?
  status           VerificationStatus @default(PENDING)
  adminComment     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("identity_verifications")
}

model AdminInvitation {
  id         String    @id @default(uuid())
  email      String
  token      String    @unique
  invitedBy  String
  role       UserRole  @default(ADMIN)
  expiresAt  DateTime
  acceptedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([email])
  @@index([token])
  @@index([expiresAt])
  @@map("admin_invitations")
}

model VerificationRequest {
  id               String             @id @default(uuid())
  userId           String
  documentFrontUrl String
  documentBackUrl  String?
  selfieUrl        String?
  extractedData    Json?
  ocrSuccess       Boolean            @default(false)
  confidenceScore  Float?
  errorMessage     String?
  rawOcrText       String?
  status           VerificationStatus @default(PENDING)
  reviewedBy       String?
  reviewedAt       DateTime?
  rejectionReason  String?
  rejectionMotif   String?
  adminComment     String?
  processingTime   Int?
  ipAddress        String?
  userAgent        String?
  submittedAt      DateTime           @default(now())
  processedAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user        User  @relation("UserVerificationRequests", fields: [userId], references: [id], onDelete: Cascade)
  validatedBy User? @relation("AdminReviewedVerifications", fields: [reviewedBy], references: [id])

  actions VerificationAction[]

  @@index([userId])
  @@index([status])
  @@index([submittedAt])
  @@index([reviewedBy])
  @@map("verification_requests")
}

model VerificationAction {
  id             String             @id @default(uuid())
  requestId      String
  action         String
  performedBy    String
  previousStatus VerificationStatus
  newStatus      VerificationStatus
  adminComment   String?
  rejectionMotif String?
  createdAt      DateTime           @default(now())

  request VerificationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  admin   User                @relation("AdminVerificationActions", fields: [performedBy], references: [id])

  @@index([requestId])
  @@index([performedBy])
  @@index([createdAt])
  @@map("verification_actions")
}

model UserAction {
  id             String         @id @default(uuid())
  userId         String
  actionType     String
  performedBy    String
  reason         String?
  motif          String?
  internalNote   String?
  duration       Int?
  suspendedUntil DateTime?
  previousStatus AccountStatus?
  newStatus      AccountStatus?
  createdAt      DateTime       @default(now())
  level          Int?
  content        String?
  admin          User           @relation("AdminUser", fields: [performedBy], references: [id])
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([performedBy])
  @@index([createdAt])
  @@map("user_actions")
}

model AdminNote {
  id             String        @id @default(uuid())
  authorId       String
  targetUserId   String
  conversationId String?
  content        String
  isPrivate      Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  author         User          @relation("AuthorUser", fields: [authorId], references: [id])
  targetUser     User          @relation("TargetUser", fields: [targetUserId], references: [id])
  conversation   Conversation? @relation(fields: [conversationId], references: [id])

  @@index([authorId])
  @@index([targetUserId])
  @@index([conversationId])
  @@map("admin_notes")
}

model UserReport {
  id             String    @id @default(uuid())
  reporterId     String
  reportedUserId String
  reason         String
  description    String?
  evidence       Json?
  status         String    @default("PENDING")
  priority       String    @default("NORMAL")
  reviewedBy     String?
  reviewedAt     DateTime?
  actionTaken    String?
  adminComment   String?
  actionMotif    String?
  createdAt      DateTime  @default(now())
  reportedUser   User      @relation("ReportedUser", fields: [reportedUserId], references: [id])
  reporter       User      @relation("Reporter", fields: [reporterId], references: [id])

  @@index([reporterId])
  @@index([reportedUserId])
  @@index([status])
  @@index([priority])
  @@map("user_reports")
}

model UserLoginHistory {
  id            String   @id @default(uuid())
  userId        String
  ipAddress     String?
  userAgent     String?
  device        String?
  location      String?
  success       Boolean  @default(true)
  failureReason String?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("user_login_history")
}

model AuditLog {
  id         String   @id @default(uuid())
  adminId    String
  action     String
  actionType String
  targetType String
  targetId   String
  details    Json?
  motif      String?
  ipAddress  String?
  createdAt  DateTime @default(now())
  admin      User     @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

model UserStats {
  id                String    @id @default(uuid())
  userId            String    @unique
  reliabilityScore  Int       @default(50)
  fraudScore        Int       @default(0)
  totalBookings     Int       @default(0)
  totalListings     Int       @default(0)
  totalReviews      Int       @default(0)
  averageRating     Float?    @default(0)
  totalSpent        Float?    @default(0)
  totalEarned       Float?    @default(0)
  lastActive        DateTime?
  loginCount        Int       @default(0)
  reportCount       Int       @default(0)
  disputeCount      Int       @default(0)
  cancellationCount Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  trustLabel        String? // "Très fiable" | "Fiable" | "Neutre" | "Prudence" | "Risqué"
  trustBadge        String? // "green" | "blue" | "gray" | "orange" | "red"
  scamFlags         String[]  @default([])
  lastScoredAt      DateTime?

  @@index([userId])
  @@index([reliabilityScore])
  @@index([fraudScore])
  @@map("user_stats")
}

model StaticPage {
  id          String              @id @default(uuid())
  type        String              @unique
  title       String
  slug        String              @unique
  htmlContent String
  version     Int                 @default(1)
  updatedAt   DateTime            @updatedAt
  updatedBy   String?
  status      String              @default("draft")
  versions    StaticPageVersion[]

  @@index([slug])
  @@index([type])
  @@map("static_pages")
}

model StaticPageVersion {
  id            String     @id @default(uuid())
  staticPageId  String
  version       Int        @default(1)
  htmlContent   String
  createdAt     DateTime   @default(now())
  createdBy     String?
  createdByUser User?      @relation("UserStaticPageVersions", fields: [createdBy], references: [id])
  staticPage    StaticPage @relation(fields: [staticPageId], references: [id], onDelete: Cascade)

  @@unique([staticPageId, version])
  @@index([staticPageId])
  @@map("static_page_versions")
}

model EmailLog {
  id         String   @id @default(uuid())
  userId     String
  actionType String
  sentBy     String
  motif      String?
  duration   Int?
  level      Int?
  status     String   @default("SENT")
  error      String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("email_logs")
}

// ============================================
// SPRINT 2 - MARKETPLACE ENGINE
// ============================================

// ============================================
// ENUMS SPRINT 2
// ============================================

enum ListingType {
  APARTMENT
  VILLA
  STUDIO
  DUPLEX
  HOUSE
  ROOM
}

enum ListingStatus {
  DRAFT
  PENDING_REVIEW
  REJECTED
  ACTIVE
  INACTIVE
  ARCHIVED
  SUSPENDED
}

enum RentalType {
  SHORT_TERM
  LONG_TERM
  BOTH
}

enum MediaType {
  IMAGE
  VIDEO
}

enum BookingStatus {
  PENDING
  ACCEPTED
  PAID
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  COMPLETED
  CANCELLED
  REJECTED
  EXPIRED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  HELD
  RELEASED
}

enum NotificationType {
  DISPUTE_OPENED // Un nouveau litige a été ouvert (pour l'autre partie)
  DISPUTE_OPENED_ADMIN // Un nouveau litige a été ouvert (pour les admins)
  DISPUTE_MESSAGE // Nouveau message dans un litige
  DISPUTE_RESOLVED // Litige résolu avec succès
  DISPUTE_REJECTED // Litige rejeté
  DISPUTE_ESCALATED // Litige escaladé (priorité haute)
  EXTENSION_ACCEPTED
  EXTENSION_REJECTED
  LISTING_REVISION_APPROVED
  LISTING_REVISION_REJECTED
  LISTING_REJECTED
  LISTING_PENDING_REVIEW
  REVIEW_REMINDER
  BOOKING_REQUEST
  BOOKING_ACCEPTED
  BOOKING_REJECTED
  BOOKING_CANCELLED
  BOOKING_CONFIRMED
  PAYMENT_RECEIVED
  PAYMENT_REFUNDED
  NEW_MESSAGE
  NEW_REVIEW
  CHECKIN_REMINDER
  CHECKOUT_REMINDER
  LISTING_ACTIVATED
  LISTING_SUSPENDED
  SEARCH_ALERT
  FAVORITE_PRICE_CHANGE
  SYSTEM_ALERT
  // 🔄 NOUVEAUX TYPES POUR SPRINT 3
  INFO_REQUEST_RECEIVED // Proprio reçoit demande
  INFO_REQUEST_ACCEPTED // Locataire : proprio a accepté
  INFO_REQUEST_REJECTED // Locataire : proprio a refusé
  INFO_REQUEST_EXPIRED // Les deux : demande expirée

  OFFER_CREATED // Proprio : offre reçue
  OFFER_ACCEPTED // Locataire : offre acceptée, paiement
  OFFER_REJECTED // Locataire : offre refusée
  OFFER_COUNTERED // Locataire : contre-offre reçue
  OFFER_EXPIRED // Les deux : offre expirée

  CONTRACT_SIGNATURE_REQUIRED // Proprio doit signer
  CONTRACT_SIGNED // Les deux : contrat signé

  REVEALED_INFO_AVAILABLE // Locataire : infos réelles dispo

  DEPOSIT_AUTHORIZED // Locataire : garantie pré-autorisée
  DEPOSIT_RELEASED // Locataire : garantie libérée
}

enum NotificationChannel {
  EMAIL
  IN_APP
  PUSH
}

enum SearchAlertFrequency {
  INSTANT
  DAILY
  WEEKLY
}

// ============================================
// MODELS SPRINT 2
// ============================================

model Listing {
  id                 String        @id @default(cuid())
  title              String        @db.VarChar(100)
  slug               String        @unique
  description        String?       @db.Text
  type               ListingType   @default(APARTMENT)
  status             ListingStatus @default(DRAFT)
  hasPendingRevision Boolean       @default(false) // ← AJOUTER CETTE LIGNE
  pendingRevision    Json? // ← AJOUTE CETTE LIGNE

  // Localisation
  governorate  String
  delegation   String
  street       String?
  neighborhood String?
  postalCode   String?
  latitude     Float?
  longitude    Float?

  // Caractéristiques
  rooms            Int        @default(1)
  bathrooms        Int        @default(1)
  maxGuests        Int?
  surfaceArea      Int
  floorNumber      Int
  hasElevator      Boolean    @default(false)
  // ✅ NOUVEAUX CHAMPS POUR CARACTÉRISTIQUES (Step 2)
  hasBalcony       Boolean    @default(false) // Balcon
  hasGarden        Boolean    @default(false) // Jardin
  hasGarage        Boolean    @default(false) // Garage
  numberOfKitchens Int        @default(1) // Nombre de cuisines
  // Prix
  rentalType       RentalType @default(SHORT_TERM)
  pricePerNight    Float?
  pricePerMonth    Float?
  securityDeposit  Float?

  // Équipements et règles
  equipment      Json?
  services       Json?
  houseRules     Json?
  customRules    String?
  // ✅ NOUVEAUX CHAMPS POUR SERVICES & RÈGLES (Step 3)
  isFurnished    Boolean @default(false) // Meublé ou non (SERVICE)
  petsAllowed    Boolean @default(false) // Animaux acceptés (REGLE)
  smokingAllowed Boolean @default(false) // Fumeurs acceptés (REGLE)

  // ✅ NOUVEAUX CHAMPS À AJOUTER
  cleaningFee            Float? @default(0) // Frais de ménage
  weekendPriceMultiplier Float? @default(1.15) // Multiplicateur weekend
  extraFees              Json?  @default("[]") // Frais supplémentaires (stockés en JSON)
  seasonalRules          Json?  @default("[]") // Règles saisonnières (stockées en JSON)

  // Statistiques
  viewCount      Int    @default(0)
  bookingCount   Int    @default(0)
  favoriteCount  Int    @default(0)
  conversionRate Float? @default(0)

  // Flags
  isArchived  Boolean @default(false)
  isBlocked   Boolean @default(false)
  blockReason String?

  vacationMode      Boolean?  @default(false)
  vacationMessage   String?
  vacationStartDate DateTime?
  vacationEndDate   DateTime?
  // Relations
  ownerId           String
  owner             User      @relation("UserListings", fields: [ownerId], references: [id], onDelete: Cascade)

  photos             ListingMedia[]
  availability       AvailabilityCalendar[]
  blockedDates       BlockedDate[]
  pricingRules       PricingRule[]
  stats              ListingStats[]
  bookings           Booking[]
  favorites          Favorite[]
  searchAlerts       SearchAlert[]          @relation("AlertListing")
  listingReports     ListingReport[]
  trustScore         Int? // 0-100
  trustLabel         String? // "Excellente" | "Fiable" | "Correcte" | "Incomplète" | "Suspecte"
  trustBadge         String? // "green" | "blue" | "gray" | "orange" | "red"
  scamProbability    Int? // 0-100
  scamFlags          String[]               @default([])
  lastScoredAt       DateTime?
  // Relations pour les co-propriétaires et historique
  historyEntries     ListingHistory[] // Pour ListingHistory
  teamMembers        TeamMember[] // Pour TeamMember
  coOwnerInvitations CoOwnerInvitation[] // Pour CoOwnerInvitation
  conversations      Conversation[]
  // SPRINT 3 - RELATIONS
  infoRequests       InfoRequest[]
  offers             Offer[]
  // Timestamps
  publishedAt        DateTime?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  archivedAt         DateTime?
  rejectionReason    String?
  rejectionDetails   String?
  rejectedAt         DateTime?
  rejectedBy         String?
  validatedAt        DateTime?
  validatedBy        String? // Référence à l'admin

  @@index([ownerId])
  @@index([status])
  @@index([type])
  @@index([governorate])
  @@index([createdAt])
  @@index([slug])
  @@map("listings")
}

model ListingMedia {
  id            String    @id @default(cuid())
  listingId     String
  listing       Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url           String    @db.Text
  thumbnailUrl  String?   @db.Text
  blurHash      String?
  type          MediaType @default(IMAGE)
  position      Int       @default(0)
  caption       String?
  isMain        Boolean   @default(false)
  isWatermarked Boolean   @default(false)
  watermarkUrl  String?   @db.Text
  width         Int?
  height        Int?
  fileSize      Int?
  uploadedAt    DateTime  @default(now())

  @@index([listingId])
  @@index([position])
  @@map("listing_media")
}

model AvailabilityCalendar {
  id                String   @id @default(cuid())
  listingId         String
  listing           Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  date              DateTime
  isAvailable       Boolean  @default(true)
  customPrice       Float?
  minStay           Int?
  maxStay           Int?
  availableBookings Int      @default(0)
  blockedReason     String?
  blockedById       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([listingId, date])
  @@index([listingId])
  @@index([date])
  @@index([isAvailable])
  @@map("availability_calendar")
}

model BlockedDate {
  id                String    @id @default(cuid())
  listingId         String
  listing           Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  startDate         DateTime
  endDate           DateTime
  reason            String?
  isRecurring       Boolean   @default(false)
  recurrencePattern String?
  recurrenceEndDate DateTime?
  blockedById       String
  createdAt         DateTime  @default(now())

  @@unique([listingId, startDate])
  @@index([listingId])
  @@index([startDate])
  @@index([endDate])
  @@map("blocked_dates")
}

model PricingRule {
  id                String   @id @default(cuid())
  listingId         String
  listing           Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  name              String
  description       String?
  priceMultiplier   Float?
  fixedPrice        Float?
  startDate         DateTime
  endDate           DateTime
  isRecurring       Boolean  @default(false)
  recurrencePattern String?
  appliesToWeekend  Boolean  @default(false)
  appliesToWeekday  Boolean  @default(false)
  daysOfWeek        Json?
  minStay           Int?
  maxStay           Int?
  isActive          Boolean  @default(true)
  priority          Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([listingId])
  @@index([startDate])
  @@index([endDate])
  @@index([isActive])
  @@map("pricing_rules")
}

model ListingStats {
  id               String   @id @default(cuid())
  listingId        String
  listing          Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  date             DateTime
  views            Int      @default(0)
  uniqueViews      Int      @default(0)
  clicks           Int      @default(0)
  messages         Int      @default(0)
  bookings         Int      @default(0)
  favorites        Int      @default(0)
  conversionRate   Float?   @default(0)
  revenue          Float?   @default(0)
  positionInSearch Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([listingId, date])
  @@index([listingId])
  @@index([date])
  @@map("listing_stats")
}

model Booking {
  id                 String        @id @default(cuid())
  reference          String        @unique
  listingId          String
  listing            Listing       @relation(fields: [listingId], references: [id], onDelete: Restrict)
  tenantId           String
  tenant             User          @relation("TenantBookings", fields: [tenantId], references: [id])
  ownerId            String?
  owner              User?         @relation("OwnerBookings", fields: [ownerId], references: [id])
  checkIn            DateTime
  checkOut           DateTime
  guests             Int?          @default(1)
  totalNights        Int
  pricePerNight      Float
  totalPrice         Float
  cleaningFee        Float?        @default(0)
  serviceFee         Float?        @default(0)
  securityDeposit    Float?        @default(0)
  totalWithFees      Float
  commission         Float?        @default(0)
  ownerPayout        Float?
  status             BookingStatus @default(PENDING)
  paymentStatus      PaymentStatus @default(PENDING)
  tenantMessage      String?       @db.Text
  ownerResponse      String?       @db.Text
  cancellationReason String?
  cancellationFee    Float?        @default(0)
  refundAmount       Float?        @default(0)
  checkedInAt        DateTime?
  checkedOutAt       DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  expiresAt          DateTime?
  confirmedAt        DateTime?
  cancelledAt        DateTime?
  // SPRINT 3 - RELATIONS

  infoRequestId         String?                @unique
  infoRequest           InfoRequest?           @relation("BookingInfoRequest", fields: [infoRequestId], references: [id])
  offerId               String?                @unique
  offer                 Offer?                 @relation("BookingOffer", fields: [offerId], references: [id])
  contractId            String?
  revealedInfo          RevealedInfo?
  contract              Contract?              @relation("BookingContract")
  actualCheckIn         DateTime?
  actualCheckOut        DateTime?
  depositReleasedAt     DateTime?
  stripePaymentIntentId String?
  stripeRefundId        String?
  conversation          Conversation?          @relation("BookingConversation", fields: [conversationId], references: [id])
  conversationId        String?                @unique
  // Relations
  payments              Payment[]
  messages              BookingMessage[]
  coTenants             CoTenant[]
  review                Review?
  dispute               Dispute?
  notifications         Notification[]
  depositAuthorizations DepositAuthorization[]
  extensions            BookingExtension[] // 👈 AJOUTEZ CETTE LIGNE dans le modèle Booking

  @@index([listingId])
  @@index([tenantId])
  @@index([ownerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([checkIn])
  @@index([checkOut])
  @@index([reference])
  @@index([infoRequestId])
  @@index([offerId])
  @@map("bookings")
}

model Payment {
