model Conversation {
  id            String       @id @default(cuid())
  listingId     String
  listing       Listing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
  ownerId       String
  owner         User         @relation("OwnerConversations", fields: [ownerId], references: [id])
  tenantId      String
  tenant        User         @relation("TenantConversations", fields: [tenantId], references: [id])
  infoRequestId String?      @unique // Lien vers la demande d'info
  infoRequest   InfoRequest? @relation(fields: [infoRequestId], references: [id])

  status        ChatStatus @default(OPEN)
  lastMessage   String?    @db.Text
  lastMessageAt DateTime   @default(now())

  // Compteurs
  unreadCountTenant Int      @default(0)
  unreadCountOwner  Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  isBlocked         Boolean  @default(false)
  booking           Booking? @relation("BookingConversation")
  bookingId         String?  @unique

  reports    Report[]
  adminNotes AdminNote[]
  messages   Message[]

  @@unique([listingId, ownerId, tenantId])
  @@index([ownerId])
  @@index([tenantId])
  @@index([status])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
  receiverId     String
  receiver       User         @relation("ReceivedMessages", fields: [receiverId], references: [id])
  content        String       @db.Text
  isRead         Boolean      @default(false)
  readAt         DateTime?
  isBlocked      Boolean      @default(false)
  blockedReason  String?
  createdAt      DateTime     @default(now())
  isSystem       Boolean      @default(false) // Message automatique du système
  type           String       @default("text") // text, voice
  voiceUrl       String?
  duration       Int? // durée en secondes pour les messages vocaux

  @@index([conversationId])
  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
  @@index([conversationId, createdAt]) // Pour le chargement paginé des messages
  @@index([receiverId, isRead]) // Pour compter les messages non lus
  @@map("messages")
}

model Block {
  id        String   @id @default(cuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("blocks", fields: [blockerId], references: [id])
  blocked User @relation("blockedBy", fields: [blockedId], references: [id])

  @@unique([blockerId, blockedId])
}

model Report {
  id             String   @id @default(cuid())
  conversationId String
  reporterId     String
  reportedUserId String
  reason         String
  status         String   @default("PENDING")
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id])
  reporter     User         @relation("reports", fields: [reporterId], references: [id])
  reportedUser User         @relation("reported", fields: [reportedUserId], references: [id])
}

// ============================================
// ENUMS SPRINT 3
// ============================================

enum InfoRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  CANCELLED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  COUNTERED
  EXPIRED
  CANCELLED
}

enum ChatStatus {
  OPEN
  EXPIRED
  CLOSED_BY_TENANT
  CLOSED_BY_OWNER
  CLOSED_BY_ADMIN
}

enum ContractStatus {
  PENDING
  SIGNED_BY_TENANT
  SIGNED_BY_OWNER
  COMPLETED
  EXPIRED
}

enum SecurityDepositStatus {
  AUTHORIZED
  CHARGED
  RELEASED
  DISPUTED
}

// ============================================
// MODELS SPRINT 3
// ============================================

model InfoRequest {
  id        String @id @default(cuid())
  reference String @unique

  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  tenantId  String
  tenant    User    @relation("InfoRequestTenant", fields: [tenantId], references: [id])
  ownerId   String
  owner     User    @relation("InfoRequestOwner", fields: [ownerId], references: [id])

  checkIn      DateTime
  checkOut     DateTime
  guests       Int?     @default(1)
  message      String?  @db.Text
  hasPets      Boolean  @default(false)
  needsBabyBed Boolean  @default(false)
  lateCheckin  Boolean  @default(false)

  status      InfoRequestStatus @default(PENDING)
  expiresAt   DateTime
  respondedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversation Conversation?
  offer        Offer?
  booking      Booking?      @relation("BookingInfoRequest")

  @@index([listingId])
  @@index([tenantId])
  @@index([ownerId])
  @@index([status])
  @@index([expiresAt])
  @@map("info_requests")
}

model Offer {
  id        String @id @default(cuid())
  reference String @unique

  infoRequestId String      @unique
  infoRequest   InfoRequest @relation(fields: [infoRequestId], references: [id])
  listingId     String
  listing       Listing     @relation(fields: [listingId], references: [id])
  tenantId      String
  tenant        User        @relation("OfferTenant", fields: [tenantId], references: [id])
  ownerId       String
  owner         User        @relation("OfferOwner", fields: [ownerId], references: [id])

  checkIn       DateTime
  checkOut      DateTime
  guests        Int?
  nights        Int
  pricePerNight Float
  cleaningFee   Float
  serviceFee    Float
  totalPrice    Float

  status OfferStatus @default(PENDING)

  counterCount        Int                  @default(0)
  parentOfferId       String?
  parentOffer         Offer?               @relation("CounterOffers", fields: [parentOfferId], references: [id])
  childOffers         Offer[]              @relation("CounterOffers")
  paymentTransactions PaymentTransaction[] // 👈 Relation inverse pour PaymentTransaction
  expiresAt           DateTime
  acceptedAt          DateTime?
  rejectedAt          DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking Booking? @relation("BookingOffer")

  @@index([listingId])
  @@index([tenantId])
  @@index([ownerId])
  @@index([status])
  @@index([expiresAt])
  @@map("offers")
}

model Contract {
  id        String @id @default(cuid())
  reference String @unique

  bookingId String  @unique
  booking   Booking @relation("BookingContract", fields: [bookingId], references: [id])

  pdfUrl  String
  content Json?

  status         ContractStatus @default(PENDING)
  tenantSignedAt DateTime?
  ownerSignedAt  DateTime?

  securityDeposit     Float?
  depositStatus       SecurityDepositStatus @default(AUTHORIZED)
  depositAuthorizedAt DateTime?
  depositChargedAt    DateTime?
  depositReleasedAt   DateTime?

  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId])
  @@index([status])
  @@map("contracts")
}

model RevealedInfo {
  id        String  @id @default(cuid())
  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id])

  exactAddress        String  @db.Text
