// Ajoute ce modèle pour la pré-autorisation des cautions
model DepositAuthorization {
  id                  String    @id @default(cuid())
  bookingId           String
  booking             Booking   @relation(fields: [bookingId], references: [id])
  amount              Float
  stripeSetupIntentId String    @unique
  status              String    @default("PENDING") // PENDING, AUTHORIZED, RELEASED, FAILED
  authorizedAt        DateTime?
  releasedAt          DateTime?
  expiresAt           DateTime?
  createdAt           DateTime  @default(now())

  @@map("deposit_authorizations")
}

model BookingExtension {
  id                String    @id @default(cuid())
  bookingId         String
  booking           Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  requestedCheckOut DateTime
  status            String    @default("PENDING") // PENDING, ACCEPTED, REJECTED
  message           String?
  rejectionReason   String?
  additionalPrice   Float? // Prix supplémentaire si applicable
  requestedBy       String // TENANT ou OWNER
  requestedAt       DateTime  @default(now())
  respondedAt       DateTime?

  @@index([bookingId])
  @@index([status])
  @@map("booking_extensions")
}
model ContactMessage {
  id        String   @id @default(cuid())
  fullName  String
  email     String
  phone     String?
  userId    String?  // ← AJOUTER CETTE LIGNE (pour les utilisateurs connectés)
  message   String   @db.Text
  status    String   @default("PENDING")
  repliedBy String?
  reply     String?  @db.Text
  repliedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id]) // ← AJOUTER

  @@index([status])
  @@index([createdAt])
  @@index([email])
  @@index([userId]) // ← AJOUTER
  @@map("contact_messages")
}