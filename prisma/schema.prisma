generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  PROPERTY_OWNER
  TENANT
  BOTH
  CO_HOST  // ✅ AJOUTER CETTE LIGNE

}

enum AccountStatus {
  ACTIVE
  TEMPORARILY_SUSPENDED
  PERMANENTLY_BANNED
  PENDING_VALIDATION
  SECURITY_LOCKED
  INACTIVE
  REJECTED
  ANUALLY_BLOCKED
  MANUALLY_BLOCKED
}

enum VerificationStatus {
  PENDING
  VALIDATED
  REJECTED
}

model User {
  id                   String                @id @default(uuid())
  clerkId              String                @unique
  email                String                @unique
  username             String?               @unique
  firstName            String?
  lastName             String?
  phoneNumber          String?               @unique
  phoneVerified        Boolean               @default(false)
  phoneVerifiedAt      DateTime?
  profilePictureUrl    String?
  bio                  String?
  spokenLanguages      String[]              @default([])
  preferredLocale      String                @default("fr")
  role                 UserRole              @default(TENANT)
  profession     String?   // Profession de l'utilisateur
  availability   Json?     // Disponibilités de contact (stocké en JSON)
  status               AccountStatus         @default(PENDING_VALIDATION)
  isEmailVerified      Boolean               @default(false)
  isPhoneVerified      Boolean               @default(false)
  isIdentityVerified   Boolean               @default(false)
  cinNumber            String?               @unique
  cinData              Json?
  verifiedAt           DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  lastLogin            DateTime?
  deletedAt            DateTime?
  suspendedUntil       DateTime?
  failedLoginAttempts  Int                   @default(0)
  escalationLevel      Int?
  vacationMode       Boolean   @default(false)
  vacationMessage    String?
  twoFactorEnabled   Boolean   @default(false)
  twoFactorRecoveryCodes String?
  writtenNotes         AdminNote[]           @relation("AuthorUser")
  adminNotes           AdminNote[]           @relation("TargetUser")
  auditLogs            AuditLog[]
  emailLogs            EmailLog[]
  staticPageVersions   StaticPageVersion[]   @relation("UserStaticPageVersions")
  actionsPerformed     UserAction[]          @relation("AdminUser")
  userActions          UserAction[]
  loginHistory         UserLoginHistory[]
  reportsReceived      UserReport[]          @relation("ReportedUser")
  reportsMade          UserReport[]          @relation("Reporter")
  stats                UserStats?
  verificationRequests VerificationRequest[] @relation("UserVerificationRequests")
  verifiedRequests     VerificationRequest[] @relation("AdminReviewedVerifications")
  verificationActions  VerificationAction[]  @relation("AdminVerificationActions")
  otpCodes             OtpCode[]
  identityVerification IdentityVerification?
   
  // ============================================
  // RELATIONS SPRINT 2
  // ============================================

  // Annonces (Listing)
  listings Listing[] @relation("UserListings")

  // Réservations
  tenantBookings Booking[] @relation("TenantBookings")
  ownerBookings  Booking[] @relation("OwnerBookings")

  // Co-locataires
  tenantCoTenants CoTenant[] @relation("TenantCoTenants")
  coTenantInvites CoTenant[] @relation("CoTenantUsers")

  // Messages
  sentMessages     BookingMessage[] @relation("SentMessages")
  receivedMessages BookingMessage[] @relation("ReceivedMessages")

  // Favoris
  favorites     Favorite[]
  favoriteLists FavoriteList[]

  // Alertes
  searchAlerts SearchAlert[]

  // Notifications
  notifications Notification[]

  // Avis
  reviewsWritten  Review[] @relation("ReviewsWritten")
  reviewsReceived Review[] @relation("ReviewsReceived")

  // Signalements
  listingReports ListingReport[] @relation("ListingReports")

  // Litiges
  openedDisputes   Dispute[] @relation("OpenedDisputes")
  assignedDisputes Dispute[] @relation("AssignedDisputes")

  // Messages litiges
  disputeMessages DisputeMessage[] @relation("DisputeMessages")

  // Historique
  searchHistory      SearchHistory[]
  mapViews           MapView[]
  listingComparisons ListingComparison[]
  listingHistories   ListingHistory[] // Pour ListingHistory (modifications faites par l'utilisateur)
  sentInvitations    CoOwnerInvitation[] @relation("CoOwnerInvitationsSent") // Pour CoOwnerInvitation (invitations envoyées)
  teamMemberships    TeamMember[] // Pour TeamMember (membres d'équipe)

  @@index([email])
  @@index([status])
  @@index([role])
  @@index([createdAt])
  @@index([cinNumber])
  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  usedAt    DateTime?

  @@index([email])
  @@index([token])
}

model OtpCode {
  id          String   @id @default(uuid())
  userId      String
  phoneNumber String
  code        String
  expiresAt   DateTime
  used        Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([phoneNumber])
  @@index([expiresAt])
  @@map("otp_codes")
}

model IdentityVerification {
  id               String             @id @default(uuid())
  userId           String             @unique
  documentFrontUrl String?
  documentBackUrl  String?
  submissionDate   DateTime?
  processedDate    DateTime?
  status           VerificationStatus @default(PENDING)
  adminComment     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("identity_verifications")
}

model AdminInvitation {
  id         String    @id @default(uuid())
  email      String
  token      String    @unique
  invitedBy  String
  role       UserRole  @default(ADMIN)
  expiresAt  DateTime
  acceptedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([email])
  @@index([token])
  @@index([expiresAt])
  @@map("admin_invitations")
}

model VerificationRequest {
  id               String             @id @default(uuid())
  userId           String
  documentFrontUrl String
  documentBackUrl  String?
  selfieUrl        String?
  extractedData    Json?
  ocrSuccess       Boolean            @default(false)
  confidenceScore  Float?
  errorMessage     String?
  rawOcrText       String?
  status           VerificationStatus @default(PENDING)
  reviewedBy       String?
  reviewedAt       DateTime?
  rejectionReason  String?
  rejectionMotif   String?
  adminComment     String?
  processingTime   Int?
  ipAddress        String?
  userAgent        String?
  submittedAt      DateTime           @default(now())
  processedAt      DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user        User  @relation("UserVerificationRequests", fields: [userId], references: [id], onDelete: Cascade)
  validatedBy User? @relation("AdminReviewedVerifications", fields: [reviewedBy], references: [id])

  actions VerificationAction[]

  @@index([userId])
  @@index([status])
  @@index([submittedAt])
  @@index([reviewedBy])
  @@map("verification_requests")
}

model VerificationAction {
  id             String             @id @default(uuid())
  requestId      String
  action         String
  performedBy    String
  previousStatus VerificationStatus
  newStatus      VerificationStatus
  adminComment   String?
  rejectionMotif String?
  createdAt      DateTime           @default(now())

  request VerificationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  admin   User                @relation("AdminVerificationActions", fields: [performedBy], references: [id])

  @@index([requestId])
  @@index([performedBy])
  @@index([createdAt])
  @@map("verification_actions")
}

model UserAction {
  id             String         @id @default(uuid())
  userId         String
  actionType     String
  performedBy    String
  reason         String?
  motif          String?
  internalNote   String?
  duration       Int?
  suspendedUntil DateTime?
  previousStatus AccountStatus?
  newStatus      AccountStatus?
  createdAt      DateTime       @default(now())
  level          Int?
  content        String?
  admin          User           @relation("AdminUser", fields: [performedBy], references: [id])
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([performedBy])
  @@index([createdAt])
  @@map("user_actions")
}

model AdminNote {
  id           String   @id @default(uuid())
  authorId     String
  targetUserId String
  content      String
  isPrivate    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  author       User     @relation("AuthorUser", fields: [authorId], references: [id])
  targetUser   User     @relation("TargetUser", fields: [targetUserId], references: [id])

  @@index([authorId])
  @@index([targetUserId])
  @@map("admin_notes")
}

model UserReport {
  id             String    @id @default(uuid())
  reporterId     String
  reportedUserId String
  reason         String
  description    String?
  evidence       Json?
  status         String    @default("PENDING")
  priority       String    @default("NORMAL")
  reviewedBy     String?
  reviewedAt     DateTime?
  actionTaken    String?
  adminComment   String?
  actionMotif    String?
  createdAt      DateTime  @default(now())
  reportedUser   User      @relation("ReportedUser", fields: [reportedUserId], references: [id])
  reporter       User      @relation("Reporter", fields: [reporterId], references: [id])

  @@index([reporterId])
  @@index([reportedUserId])
  @@index([status])
  @@index([priority])
  @@map("user_reports")
}

model UserLoginHistory {
  id            String   @id @default(uuid())
  userId        String
  ipAddress     String?
  userAgent     String?
  device        String?
  location      String?
  success       Boolean  @default(true)
  failureReason String?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("user_login_history")
}

model AuditLog {
  id         String   @id @default(uuid())
  adminId    String
  action     String
  actionType String
  targetType String
  targetId   String
  details    Json?
  motif      String?
  ipAddress  String?
  createdAt  DateTime @default(now())
  admin      User     @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

model UserStats {
  id                String    @id @default(uuid())
  userId            String    @unique
  reliabilityScore  Int       @default(50)
  fraudScore        Int       @default(0)
  totalBookings     Int       @default(0)
  totalListings     Int       @default(0)
  totalReviews      Int       @default(0)
  averageRating     Float?    @default(0)
  totalSpent        Float?    @default(0)
  totalEarned       Float?    @default(0)
  lastActive        DateTime?
  loginCount        Int       @default(0)
  reportCount       Int       @default(0)
  disputeCount      Int       @default(0)
  cancellationCount Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([reliabilityScore])
  @@index([fraudScore])
  @@map("user_stats")
}

model StaticPage {
  id          String              @id @default(uuid())
  type        String              @unique
  title       String
  slug        String              @unique
  htmlContent String
  version     Int                 @default(1)
  updatedAt   DateTime            @updatedAt
  updatedBy   String?
  status      String              @default("draft")
  versions    StaticPageVersion[]

  @@index([slug])
  @@index([type])
  @@map("static_pages")
}

model StaticPageVersion {
  id            String     @id @default(uuid())
  staticPageId  String
  version       Int        @default(1)
  htmlContent   String
  createdAt     DateTime   @default(now())
  createdBy     String?
  createdByUser User?      @relation("UserStaticPageVersions", fields: [createdBy], references: [id])
  staticPage    StaticPage @relation(fields: [staticPageId], references: [id], onDelete: Cascade)

  @@unique([staticPageId, version])
  @@index([staticPageId])
  @@map("static_page_versions")
}

model EmailLog {
  id         String   @id @default(uuid())
  userId     String
  actionType String
  sentBy     String
  motif      String?
  duration   Int?
  level      Int?
  status     String   @default("SENT")
  error      String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("email_logs")
}

// ============================================
// SPRINT 2 - MARKETPLACE ENGINE
// ============================================

// ============================================
// ENUMS SPRINT 2
// ============================================

enum ListingType {
  APARTMENT
  VILLA
  STUDIO
  DUPLEX
  HOUSE
  ROOM
}

enum ListingStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  INACTIVE
  ARCHIVED
  SUSPENDED
}

enum RentalType {
  SHORT_TERM
  LONG_TERM
  BOTH
}

enum MediaType {
  IMAGE
  VIDEO
}

enum BookingStatus {
  PENDING
  ACCEPTED
  PAID
  CONFIRMED
  CHECKED_IN
  CHECKED_OUT
  COMPLETED
  CANCELLED
  REJECTED
  EXPIRED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
  HELD
  RELEASED
}

enum NotificationType {
  BOOKING_REQUEST
  BOOKING_ACCEPTED
  BOOKING_REJECTED
  BOOKING_CANCELLED
  PAYMENT_RECEIVED
  PAYMENT_REFUNDED
  NEW_MESSAGE
  NEW_REVIEW
  CHECKIN_REMINDER
  CHECKOUT_REMINDER
  LISTING_ACTIVATED
  LISTING_SUSPENDED
  SEARCH_ALERT
  FAVORITE_PRICE_CHANGE
  SYSTEM_ALERT
}

enum NotificationChannel {
  EMAIL
  IN_APP
  PUSH
}

enum SearchAlertFrequency {
  INSTANT
  DAILY
  WEEKLY
}

// ============================================
// MODELS SPRINT 2
// ============================================

model Listing {
  id          String        @id @default(cuid())
  title       String        @db.VarChar(100)
  slug        String        @unique
  description String?       @db.Text
  type        ListingType   @default(APARTMENT)
  status      ListingStatus @default(DRAFT)

  // Localisation
  governorate  String
  delegation   String
  street       String?
  neighborhood String?
  postalCode   String?
  latitude     Float?
  longitude    Float?

  // Caractéristiques
  rooms       Int     @default(1)
  bathrooms   Int     @default(1)
  maxGuests   Int     @default(2)
  surfaceArea Int?
  floorNumber Int?
  hasElevator Boolean @default(false)

  // Prix
  rentalType      RentalType @default(SHORT_TERM)
  pricePerNight   Float?
  pricePerMonth   Float?
  securityDeposit Float?

  // Équipements et règles
  equipment   Json?
  services    Json?
  houseRules  Json?
  customRules String?
 
   
  // ✅ NOUVEAUX CHAMPS À AJOUTER
  cleaningFee           Float?        @default(0)        // Frais de ménage
  weekendPriceMultiplier Float?       @default(1.15)     // Multiplicateur weekend
  extraFees             Json?        @default("[]")      // Frais supplémentaires (stockés en JSON)
  seasonalRules         Json?        @default("[]")      // Règles saisonnières (stockées en JSON)

  // Statistiques
  viewCount      Int    @default(0)
  bookingCount   Int    @default(0)
  favoriteCount  Int    @default(0)
  conversionRate Float? @default(0)

  // Flags
  isArchived  Boolean @default(false)
  isBlocked   Boolean @default(false)
  blockReason String?

  // Relations
  ownerId String
  owner   User   @relation("UserListings", fields: [ownerId], references: [id], onDelete: Cascade)

  photos         ListingMedia[]
  availability   AvailabilityCalendar[]
  blockedDates   BlockedDate[]
  pricingRules   PricingRule[]
  stats          ListingStats[]
  bookings       Booking[]
  favorites      Favorite[]
  searchAlerts   SearchAlert[]          @relation("AlertListing")
  listingReports ListingReport[]

  // Relations pour les co-propriétaires et historique
  historyEntries     ListingHistory[] // Pour ListingHistory
  teamMembers        TeamMember[] // Pour TeamMember
  coOwnerInvitations CoOwnerInvitation[] // Pour CoOwnerInvitation

  // Timestamps
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  archivedAt  DateTime?

  @@index([ownerId])
  @@index([status])
  @@index([type])
  @@index([governorate])
  @@index([createdAt])
  @@index([slug])
  @@map("listings")
}

model ListingMedia {
  id            String    @id @default(cuid())
  listingId     String
  listing       Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url           String    @db.Text
  thumbnailUrl  String?   @db.Text
  blurHash      String?
  type          MediaType @default(IMAGE)
  position      Int       @default(0)
  caption       String?
  isMain        Boolean   @default(false)
  isWatermarked Boolean   @default(false)
  watermarkUrl  String?   @db.Text
  width         Int?
  height        Int?
  fileSize      Int?
  uploadedAt    DateTime  @default(now())

  @@index([listingId])
  @@index([position])
  @@map("listing_media")
}

model AvailabilityCalendar {
  id                String   @id @default(cuid())
  listingId         String
  listing           Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  date              DateTime
  isAvailable       Boolean  @default(true)
  customPrice       Float?
  minStay           Int?
  maxStay           Int?
  availableBookings Int      @default(0)
  blockedReason     String?
  blockedById       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([listingId, date])
  @@index([listingId])
  @@index([date])
  @@index([isAvailable])
  @@map("availability_calendar")
}

model BlockedDate {
  id                String    @id @default(cuid())
  listingId         String
  listing           Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  startDate         DateTime
  endDate           DateTime
  reason            String?
  isRecurring       Boolean   @default(false)
  recurrencePattern String?
  recurrenceEndDate DateTime?
  blockedById       String
  createdAt         DateTime  @default(now())

  @@unique([listingId, startDate])
  @@index([listingId])
  @@index([startDate])
  @@index([endDate])
  @@map("blocked_dates")
}

model PricingRule {
  id                String   @id @default(cuid())
  listingId         String
  listing           Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  name              String
  description       String?
  priceMultiplier   Float?
  fixedPrice        Float?
  startDate         DateTime
  endDate           DateTime
  isRecurring       Boolean  @default(false)
  recurrencePattern String?
  appliesToWeekend  Boolean  @default(false)
  appliesToWeekday  Boolean  @default(false)
  daysOfWeek        Json?
  minStay           Int?
  maxStay           Int?
  isActive          Boolean  @default(true)
  priority          Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([listingId])
  @@index([startDate])
  @@index([endDate])
  @@index([isActive])
  @@map("pricing_rules")
}

model ListingStats {
  id               String   @id @default(cuid())
  listingId        String
  listing          Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  date             DateTime
  views            Int      @default(0)
  uniqueViews      Int      @default(0)
  clicks           Int      @default(0)
  messages         Int      @default(0)
  bookings         Int      @default(0)
  favorites        Int      @default(0)
  conversionRate   Float?   @default(0)
  revenue          Float?   @default(0)
  positionInSearch Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([listingId, date])
  @@index([listingId])
  @@index([date])
  @@map("listing_stats")
}

model Booking {
  id                 String        @id @default(cuid())
  reference          String        @unique
  listingId          String
  listing            Listing       @relation(fields: [listingId], references: [id], onDelete: Restrict)
  tenantId           String
  tenant             User          @relation("TenantBookings", fields: [tenantId], references: [id])
  ownerId            String?
  owner              User?         @relation("OwnerBookings", fields: [ownerId], references: [id])
  checkIn            DateTime
  checkOut           DateTime
  guests             Int           @default(1)
  totalNights        Int
  pricePerNight      Float
  totalPrice         Float
  cleaningFee        Float?        @default(0)
  serviceFee         Float?        @default(0)
  securityDeposit    Float?        @default(0)
  totalWithFees      Float
  commission         Float?        @default(0)
  ownerPayout        Float?
  status             BookingStatus @default(PENDING)
  paymentStatus      PaymentStatus @default(PENDING)
  tenantMessage      String?       @db.Text
  ownerResponse      String?       @db.Text
  cancellationReason String?
  cancellationFee    Float?        @default(0)
  refundAmount       Float?        @default(0)
  checkedInAt        DateTime?
  checkedOutAt       DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  expiresAt          DateTime?
  confirmedAt        DateTime?
  cancelledAt        DateTime?

  // Relations
  payments      Payment[]
  messages      BookingMessage[]
  coTenants     CoTenant[]
  review        Review?
  dispute       Dispute?
  notifications Notification[]

  @@index([listingId])
  @@index([tenantId])
  @@index([ownerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([checkIn])
  @@index([checkOut])
  @@index([reference])
  @@map("bookings")
}

model Payment {
  id                    String        @id @default(cuid())
  bookingId             String
  booking               Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  amount                Float
  currency              String        @default("TND")
  type                  String
  status                PaymentStatus @default(PENDING)
  provider              String        @default("KONNECT")
  providerTransactionId String?
  providerData          Json?
  receiptUrl            String?
  refundAmount          Float?
  refundReason          String?
  refundedAt            DateTime?
  paidAt                DateTime?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([bookingId])
  @@index([status])
  @@index([providerTransactionId])
  @@map("payments")
}

model CoTenant {
  id                      String    @id @default(cuid())
  bookingId               String
  booking                 Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  tenantId                String
  coTenantId              String
  inviteeEmail            String
  invitationToken         String?   @unique
  status                  String    @default("PENDING")
  fullName                String?
  phoneNumber             String?
  email                   String?
  cinNumber               String?
  isIdentityVerified      Boolean   @default(false)
  isResponsibleForPayment Boolean   @default(false)
  paymentSharePercent     Int?
  canCommunicateWithOwner Boolean   @default(true)
  hasSignedContract       Boolean   @default(false)
  invitedAt               DateTime  @default(now())
  acceptedAt              DateTime?

  tenant   User  @relation("TenantCoTenants", fields: [tenantId], references: [id])
  coTenant User? @relation("CoTenantUsers", fields: [coTenantId], references: [id])

  @@index([bookingId])
  @@index([invitationToken])
  @@map("co_tenants")
}

model BookingMessage {
  id          String    @id @default(cuid())
  bookingId   String
  booking     Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  senderId    String
  receiverId  String
  content     String    @db.Text
  isRead      Boolean   @default(false)
  readAt      DateTime?
  attachments Json?
  createdAt   DateTime  @default(now())

  sender   User @relation("SentMessages", fields: [senderId], references: [id])
  receiver User @relation("ReceivedMessages", fields: [receiverId], references: [id])

  @@index([bookingId])
  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
  @@map("booking_messages")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  listId    String?
  notes     String?
  createdAt DateTime @default(now())

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  list FavoriteList? @relation(fields: [listId], references: [id])

  @@unique([userId, listingId])
  @@index([userId])
  @@index([listingId])
  @@map("favorites")
}

model FavoriteList {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  isPublic    Boolean  @default(false)
  shareToken  String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  favorites Favorite[]

  @@index([userId])
  @@map("favorite_lists")
}

model SearchAlert {
  id         String               @id @default(cuid())
  userId     String
  name       String
  criteria   Json
  frequency  SearchAlertFrequency @default(DAILY)
  isActive   Boolean              @default(true)
  lastSentAt DateTime?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  matchedListings Listing[]      @relation("AlertListing")
  notifications   Notification[]

  @@index([userId])
  @@index([isActive])
  @@map("search_alerts")
}

model Notification {
  id          String                @id @default(cuid())
  userId      String
  type        NotificationType
  title       String
  content     String                @db.Text
  data        Json?
  channels    NotificationChannel[]
  isRead      Boolean               @default(false)
  readAt      DateTime?
  sentAt      DateTime?
  deliveredAt DateTime?
  createdAt   DateTime              @default(now())

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking   Booking?     @relation(fields: [bookingId], references: [id])
  bookingId String?
  alert     SearchAlert? @relation(fields: [alertId], references: [id])
  alertId   String?

  @@index([userId])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model Review {
  id          String    @id @default(cuid())
  bookingId   String    @unique
  booking     Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reviewerId  String
  targetId    String
  targetType  String
  rating      Int
  comment     String?   @db.Text
  response    String?   @db.Text
  responseAt  DateTime?
  isPublished Boolean   @default(true)
  isFlagged   Boolean   @default(false)
  flagReason  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  reviewer User @relation("ReviewsWritten", fields: [reviewerId], references: [id])
  target   User @relation("ReviewsReceived", fields: [targetId], references: [id])

  @@index([bookingId])
  @@index([reviewerId])
  @@index([targetId])
  @@index([targetType])
  @@index([rating])
  @@map("reviews")
}

model ListingReport {
  id          String    @id @default(cuid())
  listingId   String
  listing     Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reporterId  String
  reason      String
  description String?   @db.Text
  status      String    @default("PENDING")
  reviewedBy  String?
  reviewedAt  DateTime?
  actionTaken String?
  adminNote   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  reporter User @relation("ListingReports", fields: [reporterId], references: [id])

  @@index([listingId])
  @@index([reporterId])
  @@index([status])
  @@map("listing_reports")
}

model Dispute {
  id              String    @id @default(cuid())
  bookingId       String    @unique
  booking         Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  openedBy        String
  type            String
  description     String    @db.Text
  status          String    @default("OPEN")
  priority        String    @default("NORMAL")
  assignedTo      String?
  resolution      String?   @db.Text
  resolutionDate  DateTime?
  refundAmount    Float?
  depositWithheld Boolean?  @default(false)
  withheldAmount  Float?
  evidence        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  resolvedAt      DateTime?

  openedByUser  User             @relation("OpenedDisputes", fields: [openedBy], references: [id])
  assignedAdmin User?            @relation("AssignedDisputes", fields: [assignedTo], references: [id])
  messages      DisputeMessage[]

  @@index([bookingId])
  @@index([status])
  @@index([priority])
  @@map("disputes")
}

model DisputeMessage {
  id          String   @id @default(cuid())
  disputeId   String
  dispute     Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)
  senderId    String
  content     String   @db.Text
  attachments Json?
  isInternal  Boolean  @default(false)
  createdAt   DateTime @default(now())

  sender User @relation("DisputeMessages", fields: [senderId], references: [id])

  @@index([disputeId])
  @@index([createdAt])
  @@map("dispute_messages")
}

model SearchHistory {
  id               String    @id @default(cuid())
  userId           String
  query            String?
  filters          Json?
  resultsCount     Int
  clickedListingId String?
  clickedAt        DateTime?
  sessionId        String?
  createdAt        DateTime  @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@index([sessionId])
  @@map("search_history")
}

model MapView {
  id                String   @id @default(cuid())
  sessionId         String
  userId            String?
  centerLat         Float
  centerLng         Float
  zoomLevel         Float
  bounds            Json?
  visibleListingIds String[]
  viewedAt          DateTime @default(now())
  expiresAt         DateTime

  user User? @relation(fields: [userId], references: [id])

  @@index([sessionId])
  @@index([userId])
  @@index([expiresAt])
  @@map("map_views")
}

model ListingComparison {
  id         String   @id @default(cuid())
  tenantId   String
  name       String
  listingIds String[]
  result     Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant User @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("listing_comparisons")
}

model Equipment {
  id        String   @id @default(cuid())
  name      String   @unique
  nameAr    String?
  icon      String?
  category  String
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([category])
  @@index([isActive])
  @@map("equipment")
}

model Governorate {
  id        String  @id @default(cuid())
  code      String  @unique
  name      String
  nameAr    String
  centerLat Float?
  centerLng Float?
  order     Int     @default(0)
  isActive  Boolean @default(true)

  delegations Delegation[]

  @@map("governorates")
}

model Delegation {
  id            String  @id @default(cuid())
  governorateId String
  code          String  @unique
  name          String
  nameAr        String
  postalCode    String?
  latitude      Float?
  longitude     Float?
  order         Int     @default(0)
  isActive      Boolean @default(true)

  governorate Governorate @relation(fields: [governorateId], references: [id], onDelete: Cascade)

  @@index([governorateId])
  @@map("delegations")
}

model ListingHistory {
  id            String   @id @default(cuid())
  listingId     String
  listing       Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  actionType    String // 'UPDATE', 'STATUS_CHANGE', 'PRICE_UPDATE', 'PHOTO_UPDATE'
  fieldName     String? // Nom du champ modifié (ex: 'pricePerNight', 'title', 'status')
  oldValue      Json? // Ancienne valeur
  newValue      Json? // Nouvelle valeur
  changedBy     String // userId de la personne qui a fait la modification
  changedByUser User     @relation(fields: [changedBy], references: [id])
  createdAt     DateTime @default(now())
  ipAddress     String?
  userAgent     String?

  @@index([listingId])
  @@index([createdAt])
  @@index([actionType])
  @@map("listing_histories")
}

// Invitations de co-propriétaires
model CoOwnerInvitation {
  id           String    @id @default(cuid())
  listingId    String
  listing      Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  inviterId    String
  inviter      User      @relation("CoOwnerInvitationsSent", fields: [inviterId], references: [id])
  inviteeEmail String
  inviteeName  String?
  role         String    @default("CO_HOST") // 'CO_HOST', 'MANAGER', 'VIEWER'
  permissions  Json? // Permissions spécifiques
  status       String    @default("PENDING") // 'PENDING', 'ACCEPTED', 'REJECTED', 'EXPIRED'
  token        String    @unique
  message      String?   @db.Text
  expiresAt    DateTime
  acceptedAt   DateTime?
  rejectedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([listingId])
  @@index([inviteeEmail])
  @@index([token])
  @@index([status])
  @@map("co_owner_invitations")
}

// Membre de l'équipe (co-propriétaire accepté)
model TeamMember {
  id                String    @id @default(cuid())
  listingId         String
  listing           Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  userId            String
  user              User      @relation(fields: [userId], references: [id])
  role              String    @default("CO_HOST") // 'OWNER', 'CO_HOST', 'MANAGER', 'VIEWER'
  permissions       Json? // Permissions granulaires
  canEdit           Boolean   @default(false)
  canManageBookings Boolean   @default(false)
  canViewRevenue    Boolean   @default(false)
  canManageTeam     Boolean   @default(false)
  invitedBy         String
  invitedAt         DateTime  @default(now())
  joinedAt          DateTime?
  isActive          Boolean   @default(true)

  @@unique([listingId, userId])
  @@index([listingId])
  @@index([userId])
  @@map("team_members")
}
